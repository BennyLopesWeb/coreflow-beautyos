{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_PUSH_ENABLED": "true",
        "EXPO_PUBLIC_USE_COREFLOW_V1": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_PUSH_ENABLED": "true",
        "EXPO_PUBLIC_USE_COREFLOW_V1": "true",
        "EXPO_PUBLIC_UNIVERSAL_LINK_HOST": "app.coreflow.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_PUSH_ENABLED": "true",
        "EXPO_PUBLIC_USE_COREFLOW_V1": "true",
        "EXPO_PUBLIC_UNIVERSAL_LINK_HOST": "app.coreflow.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your-apple-id@email.com",
        "ascAppId": "0000000000",
        "appleTeamId": "TEAMID12345"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
