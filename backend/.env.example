# CoreFlow API — variáveis de ambiente (copie para .env)

# SQLite (dev local)
DATABASE_URL=sqlite:///./trancapro.db

# MySQL (Docker: make docker-mysql-up)
# DATABASE_URL=mysql+pymysql://coreflow:coreflow@localhost:3306/coreflow?charset=utf8mb4

DEBUG=false
APP_ENV=development
LEGACY_SUNSET_ENABLED=true
LEGACY_SUNSET_DATE=Sat, 01 Jan 2028 00:00:00 GMT

# R3-F1: local off|warn; staging/production block (booking + payments + fila)
CORE_ENFORCEMENT_MODE=off
# CORE_ENFORCEMENT_MODE=block
# APP_ENV=staging
# APP_ENV=production

# R3-F2: booking write path legado (ReservationService) removido — default true.
# Desligar é apenas kill-switch de emergência (sem fallback legado; escrita bloqueia com 409).
FEATURE_BOOKING_CORE_ENABLED=true

# R4-F2 (ADR-024 sunset / RFC-003 M7): dual-write outbound (project_*) para
# agendamentos/payments legado — default false. Reativar restaura o dual-write
# imediatamente (kill-switch de rollback, sem deploy de código).
FEATURE_BOOKING_LEGACY_PROJECTION_ENABLED=false

SECRET_KEY=change-me-in-production
