# CoreFlow API — variáveis de ambiente (copie para .env)

# SQLite (dev local)
DATABASE_URL=sqlite:///./trancapro.db

# MySQL (Docker: make docker-mysql-up)
# DATABASE_URL=mysql+pymysql://coreflow:coreflow@localhost:3306/coreflow?charset=utf8mb4

DEBUG=false
APP_ENV=development
LEGACY_SUNSET_ENABLED=true
LEGACY_SUNSET_DATE=Sat, 01 Jan 2028 00:00:00 GMT

# R2-F6: local off|warn; staging block (booking legado only — ADR-033)
CORE_ENFORCEMENT_MODE=off
# CORE_ENFORCEMENT_MODE=block
# APP_ENV=staging

SECRET_KEY=change-me-in-production
