{
  "aws_region": "us-east-1",
  "bucket_name": "coreflow-cdn-prod",
  "cdn_prefix": "cdn",
  "cloudfront_price_class": "PriceClass_All",
  "cloudfront_aliases": [
    "app.coreflow.app",
    "clinic.coreflow.app",
    "sports.coreflow.app"
  ],
  "tenant_behaviors": [
    {
      "plugin_id": "beauty",
      "path_pattern": "/beauty/.well-known/*",
      "cdn_host": "app.coreflow.app",
      "default_ttl": 86400,
      "compress": true
    },
    {
      "plugin_id": "clinic",
      "path_pattern": "/clinic/.well-known/*",
      "cdn_host": "clinic.coreflow.app",
      "default_ttl": 86400,
      "compress": true
    },
    {
      "plugin_id": "sports",
      "path_pattern": "/sports/.well-known/*",
      "cdn_host": "sports.coreflow.app",
      "default_ttl": 86400,
      "compress": true
    }
  ],
  "well_known_cache_seconds": 86400,
  "tags": {
    "Project": "CoreFlow",
    "Component": "CDN",
    "Version": "2.12.0-r4-f9",
    "Environment": "prod",
    "CostCenter": "platform-coreflow",
    "Owner": "platform-team"
  }
}